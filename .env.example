# Groq AI API Configuration
GROQ_API_KEY=your_groq_key_here
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile

# Alternative (if using Grok)
# GROK_API_KEY=your_grok_key_here
# GROK_API_URL=https://api.x.ai/v1/chat/completions
# GROK_MODEL=grok-beta

# Django settings
DEBUG=True
SECRET_KEY=django-insecure-3ana!9zs83!tkoy7nck(xqmx8)rb^2)ih=jgs#&b%gg*n1v=w)
ALLOWED_HOSTS=localhost,127.0.0.1

# Google Maps JavaScript API (pages de démo biens/ajouter/ et biens/carte/)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Celery / Redis (leave REDIS_URL empty to use in-memory cache locally)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_URL=

# CinetPay (paiement Mobile Money / carte - https://cinetpay.com)
CINETPAY_API_KEY=your_cinetpay_api_key
CINETPAY_SITE_ID=your_cinetpay_site_id
CINETPAY_NOTIFY_URL=http://localhost:8000/api/paiements/webhook/
CINETPAY_RETURN_URL=http://localhost:3000/paiement/confirmation

# SMTP email configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
SERVER_EMAIL=your-email@gmail.com
EMAIL_TIMEOUT=10
